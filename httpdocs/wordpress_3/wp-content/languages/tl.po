msgstr "Maaari kang mag-navigate sa ibang mga pahina sa iyong site habang ginagamit ang Customizer upang tingnan at i-edit ang mga widget na ipinapakita sa mga pahinang iyon."

#. translators: %s: The total number of widget areas registered.
#: wp-includes/class-wp-customize-widgets.php:784
msgid "Your theme has %s widget area, but this particular page does not display it."
msgid_plural "Your theme has %s widget areas, but this particular page does not display them."
msgstr[0] "Ang iyong tema ay may %s widget area, ngunit hindi ito ipinapakita ng partikular na pahinang ito."
msgstr[1] "Ang iyong tema ay may %s na mga widget area, ngunit hindi ito ipinapakita ng partikular na pahinang ito."

#: wp-includes/class-wp-customize-widgets.php:775
msgid "Your theme has 1 widget area, but this particular page does not display it."
msgstr "Ang iyong tema ay may 1 widget area, ngunit hindi ito ipinapakita ng partikular na pahinang ito."

#. translators: %s: The number of other widget areas registered but not
#. rendered.
#: wp-includes/class-wp-customize-widgets.php:760
msgid "Your theme has %s other widget area, but this particular page does not display it."
msgid_plural "Your theme has %s other widget areas, but this particular page does not display them."
msgstr[0] "Ang iyong tema ay may %s pang widget area, ngunit hindi ito ipinapakita ng partikular na pahinang ito."
msgstr[1] "Ang iyong tema ay may %s pang mga widget area, ngunit hindi ito ipinapakita ng partikular na pahinang ito."

#: wp-includes/class-wp-customize-widgets.php:751
msgid "Your theme has 1 other widget area, but this particular page does not display it."
msgstr "Ang iyong tema ay may 1 pang widget area, ngunit hindi ito ipinapakita ng partikular na pahinang ito."

#: wp-includes/admin-bar.php:422
msgid "Manage Site"
msgstr "Pamahalaan ang Site"

#. translators: %s: Header height in pixels.
#: wp-includes/customize/class-wp-customize-header-image-control.php:231
msgid "Click &#8220;Add New Image&#8221; to upload an image file from your computer. Your theme works best with an image with a header height of %s pixels &#8212; you&#8217;ll be able to crop your image once you upload it for a perfect fit."
msgstr "I-click ang &#8220;Magdagdag ng Bagong Larawan&#8221; para mag-upload ng image file mula sa iyong computer. Pinakamahusay na gumagana ang iyong tema sa isang larawang may taas ng header na %s pixels &#8212; magagawa mong i-crop ang iyong larawan kapag na-upload mo ito para sa isang perpektong akma."

#. translators: %s: Header width in pixels.
#: wp-includes/customize/class-wp-customize-header-image-control.php:225
msgid "Click &#8220;Add New Image&#8221; to upload an image file from your computer. Your theme works best with an image with a header width of %s pixels &#8212; you&#8217;ll be able to crop your image once you upload it for a perfect fit."
msgstr "I-click ang &#8220;Magdagdag ng Bagong Larawan&#8221; para mag-upload ng image file mula sa iyong computer. Pinakamahusay na gumagana ang iyong tema sa isang larawang may lapad ng header na %s pixels &#8212; magagawa mong i-crop ang iyong larawan kapag na-upload mo ito para sa isang perpektong akma."

#. translators: %s: Header size in pixels.
#: wp-includes/customize/class-wp-customize-header-image-control.php:219
msgid "Click &#8220;Add New Image&#8221; to upload an image file from your computer. Your theme works best with an image with a header size of %s pixels &#8212; you&#8217;ll be able to crop your image once you upload it for a perfect fit."
msgstr "I-click ang &#8220;Magdagdag ng Bagong Larawan&#8221; para mag-upload ng image file mula sa iyong computer. Pinakamahusay na gumagana ang iyong tema sa isang larawang may sukat ng header na %s pixels &#8212; magagawa mong i-crop ang iyong larawan kapag na-upload mo ito para sa isang perpektong akma."

#: wp-includes/customize/class-wp-customize-header-image-control.php:215
msgid "Click &#8220;Add New Image&#8221; to upload an image file from your computer. Your theme works best with an image that matches the size of your video &#8212; you&#8217;ll be able to crop your image once you upload it for a perfect fit."
msgstr "I-click ang &#8220;Magdagdag ng Bagong Larawan&#8221; para mag-upload ng image file mula sa iyong computer. Pinakamahusay na gumagana ang iyong tema sa isang larawang tumutugma sa sukat ng iyong video &#8212; magagawa mong i-crop ang iyong larawan kapag na-upload mo ito para sa isang perpektong akma."

