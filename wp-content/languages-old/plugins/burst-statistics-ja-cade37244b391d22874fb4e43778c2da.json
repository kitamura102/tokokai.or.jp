s":["\u30ec\u30dd\u30fc\u30c8\u540d\u306f3\u6587\u5b57\u4ee5\u4e0a\u306b\u3057\u3066\u304f\u3060\u3055\u3044"],"Report name is required":["\u30ec\u30dd\u30fc\u30c8\u540d\u304c\u5fc5\u8981\u3067\u3059"],"Story URL:":["\u30b9\u30c8\u30fc\u30ea\u30fcURL:"],"No content selected":["\u30b3\u30f3\u30c6\u30f3\u30c4\u304c\u9078\u629e\u3055\u308c\u3066\u3044\u307e\u305b\u3093"],"Content:":["\u30b3\u30f3\u30c6\u30f3\u30c4:"],"No recipients added":["\u53d7\u4fe1\u8005\u304c\u8ffd\u52a0\u3055\u308c\u3066\u3044\u307e\u305b\u3093"],"Recipients:":["\u53d7\u53d6\u4eba:"],"Scheduled:":["\u30b9\u30b1\u30b8\u30e5\u30fc\u30eb\u6e08\u307f:"],"Manual download":["\u624b\u52d5\u30c0\u30a6\u30f3\u30ed\u30fc\u30c9"],"Scheduled email, sent automatically":["\u30b9\u30b1\u30b8\u30e5\u30fc\u30eb\u3055\u308c\u305f\u30e1\u30fc\u30eb\u3001\u81ea\u52d5\u9001\u4fe1"],"Delivers:":["\u63d0\u4f9b\u5185\u5bb9:"],"Copy URL":["URL\u3092\u30b3\u30d4\u30fc"],"Recipients":["\u53d7\u4fe1\u8005"],"Duplicate email addresses are not allowed":["\u91cd\u8907\u3057\u305f\u30e1\u30fc\u30eb\u30a2\u30c9\u30ec\u30b9\u306f\u4f7f\u7528\u3067\u304d\u307e\u305b\u3093"],"One or more email addresses are invalid":["1\u3064\u4ee5\u4e0a\u306e\u30e1\u30fc\u30eb\u30a2\u30c9\u30ec\u30b9\u304c\u7121\u52b9\u3067\u3059"],"Maximum %d recipients allowed":["\u6700\u5927 %d \u4eba\u306e\u53d7\u4fe1\u8005\u304c\u8a31\u53ef\u3055\u308c\u3066\u3044\u307e\u3059"],"Please add at least one recipient":["\u5c11\u306a\u304f\u3068\u30821\u4eba\u306e\u53d7\u4fe1\u8005\u3092\u8ffd\u52a0\u3057\u3066\u304f\u3060\u3055\u3044"],"Add email...":["\u30e1\u30fc\u30eb\u3092\u8ffd\u52a0..."],"List view":["\u30ea\u30b9\u30c8\u30d3\u30e5\u30fc"],"Add content":["\u30b3\u30f3\u30c6\u30f3\u30c4\u3092\u8ffd\u52a0"],"content blocks":["\u30b3\u30f3\u30c6\u30f3\u30c4\u30d6\u30ed\u30c3\u30af"],"content block":["\u30b3\u30f3\u30c6\u30f3\u30c4\u30d6\u30ed\u30c3\u30af"],"(has comment)":["\uff08\u30b3\u30e1\u30f3\u30c8\u3042\u308a\uff09"],"Select block":["\u30d6\u30ed\u30c3\